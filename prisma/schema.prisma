datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id
  name      String   @unique
  password  String
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Todo {
  id        String   @id @default(cuid())
  userId    String   @default("usr_olly")
  text      String
  done      Boolean  @default(false)
  position  Int      @default(0)
  date      String   @default("")   // YYYY-MM-DD
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Note {
  id        String   @id   // "{userId}-note-{date}"
  userId    String   @default("usr_olly")
  content   String   @default("")
  updatedAt DateTime @updatedAt
}

model Habit {
  id        String       @id @default(cuid())
  userId    String       @default("usr_olly")
  name      String
  position  Int          @default(0)
  createdAt DateTime     @default(now())
  checks    HabitCheck[]
}

model HabitCheck {
  id      String   @id @default(cuid())
  habitId String
  date    DateTime @db.Date
  checked Boolean  @default(true)
  habit   Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)

  @@unique([habitId, date])
}

model TimeBlock {
  id          String   @id @default(cuid())
  userId      String   @default("usr_olly")
  task        String
  tasks       Json     @default("[]")
  isSuperBlock Boolean @default(false)
  startMinute Int
  endMinute   Int
  color       String
  date        DateTime @db.Date
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model WatchlistItem {
  id        String   @id @default(cuid())
  userId    String   @default("usr_olly")
  symbol    String
  name      String   @default("")
  position  Int      @default(0)
  createdAt DateTime @default(now())

  @@unique([userId, symbol])
}

model UserPreference {
  userId String @default("usr_olly")
  key    String
  value  String

  @@id([userId, key])
}
